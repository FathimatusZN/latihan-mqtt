# ============================================================
#  .gitignore — File & folder yang TIDAK perlu di-push ke GitHub
# ============================================================

# Environment variables (RAHASIA — jangan di-commit!)
backend/.env
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
venv/
.venv/
env/
*.egg

# VS Code
.vscode/
*.code-workspace

# Node (jika ada)
node_modules/

# Docker volumes
postgres_data/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/