# ============================================================
#  FILE    : backend/.env.example
#  FUNGSI  : Contoh konfigurasi environment 
# ============================================================

# --- DATABASE POSTGRESQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=monitoring_pabrik
DB_USER=yourusername
DB_PASSWORD=yourpassword

# --- MQTT BROKER ---
# Untuk development lokal (python main.py langsung):
MQTT_BROKER=your_mqtt_broker_host
MQTT_PORT=your_mqtt_port

# Untuk Docker, di-override via docker-compose environment:
# MQTT_BROKER=mosquitto

# Topic yang akan di-subscribe
# Format: pabrik/{nama_pabrik}/mesin/arus
MQTT_TOPIC=your_mqtt_topic

# Client ID unik untuk identifikasi di broker
MQTT_CLIENT_ID=your_client_id

# --- BACKEND API ---
API_HOST=your_api_host  
API_PORT=your_api_port

